# =============================================================================
# Blitzy Slack — Environment Variable Template
# =============================================================================
# Copy this file to `.env` and adjust values as needed:
#
#     cp .env.example .env
#
# The root `.env` is git-ignored; only this template (`.env.example`) is
# committed. `make local` / `make up` load the root `.env` and export it, so
# docker-compose.yml picks up the POSTGRES_* / REDIS_PORT values below and the
# API and web dev servers pick up the rest.
#
# The API-side variables are validated by the Zod env loader at
# packages/api/src/config/env.ts (it fails fast on anything missing or
# malformed). The VITE_-prefixed variables are exposed to the web client by
# Vite's own loader.
#
# Format rules: one KEY=VALUE per line; no shell-style ${INTERPOLATION}
# (dotenv parsers differ); placeholders only — never commit real secrets.
# See /docs/decision-log.md for the rationale behind each choice.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
# Selects runtime behavior across the stack. One of: development | test | production.
NODE_ENV=development

# -----------------------------------------------------------------------------
# Docker infrastructure (consumed by docker-compose.yml)
# -----------------------------------------------------------------------------
# These configure the PostgreSQL 16 and Redis 7 containers started by
# `make up` / `make local`. docker-compose.yml reads them with the same
# defaults shown here, so the stack works out of the box. Keep DATABASE_URL
# and REDIS_URL (below) in sync with any change made to these values.
POSTGRES_USER=slack
POSTGRES_PASSWORD=slack
POSTGRES_DB=slack_dev
# Host port mapped to the container's 5432; must match DATABASE_URL's port.
POSTGRES_PORT=5432
# Host port mapped to the container's 6379; must match REDIS_URL's port.
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string used by Prisma (packages/db) and the API.
# Components mirror the POSTGRES_* values above: slack / slack / slack_dev.
# The connection_limit / pool_timeout parameters bound the Prisma connection
# pool so it cannot exhaust Postgres max_connections under load; packages/db
# applies these same defaults when they are omitted here. See /docs/decision-log.md.
DATABASE_URL=postgresql://slack:slack@localhost:5432/slack_dev?schema=public&connection_limit=10&pool_timeout=20

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Redis connection string used by:
#   - @socket.io/redis-adapter — cross-instance pub/sub for Socket.io (Rule 2)
#   - the presence service — TTL heartbeat keys
# Port mirrors REDIS_PORT above.
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Secret used to sign and verify JWTs for both HTTP routes and the Socket.io
# handshake. Use 32+ bytes of cryptographically random data.
# Generate one with:  openssl rand -hex 32
# CHANGE THIS before any environment beyond local development.
JWT_SECRET=dev-only-change-me-in-production-please-32chars-min
# Token lifetime; accepts an ms-style duration string ("7d", "1h", "30m", "60s").
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# File uploads
# -----------------------------------------------------------------------------
# Directory where multer disk storage writes uploaded attachments. Relative to
# the API package's working directory, or an absolute path. Git-ignored.
FILE_UPLOAD_PATH=./uploads
# Per-file upload cap in megabytes. Enforced server-side by multer and
# client-side by the upload UI to fail fast.
MAX_FILE_SIZE_MB=10

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
# Port the Express + Socket.io server listens on. The Makefile derives the
# health-check URL (http://localhost:$PORT/api/health) from this value.
# Optional — defaults to 3000 when unset.
PORT=3000

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Origin allowed by the API's CORS middleware; must match VITE_APP_URL below.
# Optional — defaults to http://localhost:5173 when unset.
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# bcrypt cost factor for password hashing. Minimum 10 is enforced by the env
# loader. Optional — defaults to 10 when unset.
BCRYPT_ROUNDS=10

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# Pino log level override. One of: fatal | error | warn | info | debug | trace |
# silent. Optional — when unset the logger derives it from NODE_ENV.
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Web client (Vite)
# -----------------------------------------------------------------------------
# Vite exposes ONLY VITE_-prefixed variables to client code. These are read by
# the web package. The Socket.io server shares the API origin (it is mounted on
# the same HTTP server), so VITE_WS_URL normally equals VITE_API_URL.

# Base URL the web client uses for REST API calls.
VITE_API_URL=http://localhost:3000
# WebSocket URL for the Socket.io client (same origin as the API).
VITE_WS_URL=http://localhost:3000
# Origin of the web app itself; used by playwright.config.ts (baseURL) and the
# API CORS allow-list. Matches the Vite dev server's default port (5173).
VITE_APP_URL=http://localhost:5173
