# ----------------------------------------------------------------------------
# blitzy-slack environment template. Copy to `.env` and adjust as needed.
# `make local` reads these; docker-compose.yml consumes the POSTGRES_*/REDIS_*.
# ----------------------------------------------------------------------------

# Runtime
NODE_ENV=development

# --- Docker infrastructure (consumed by docker-compose.yml) ---
POSTGRES_USER=slack
POSTGRES_PASSWORD=slack
POSTGRES_DB=slack_dev
POSTGRES_PORT=5432
REDIS_PORT=6379

# --- API (packages/api) ---
DATABASE_URL=postgresql://slack:slack@localhost:5432/slack_dev?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-only-change-me-in-production-please-32chars-min
JWT_EXPIRES_IN=7d
FILE_UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=10
API_PORT=3000

# --- Web (packages/web, Vite) ---
VITE_API_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3000
VITE_APP_URL=http://localhost:5173
