{
  "name": "@app/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types, Zod schemas, and Socket.io event constants for the Blitzy Slack PoC.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types/*": "./src/types/*.ts",
    "./schemas/*": "./src/schemas/*.ts",
    "./constants/*": "./src/constants/*.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.0"
  }
}
