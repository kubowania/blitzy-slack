# =============================================================================
# @app/api — Environment Variable Template (API-side subset)
# =============================================================================
# Copy this file to `packages/api/.env` when running the API package in
# isolation:
#
#     cp packages/api/.env.example packages/api/.env
#
# In normal operation you do NOT need this copy: `make local` / `make up` load
# the ROOT `.env` (a superset that also carries the docker-compose POSTGRES_*
# values and the web-only VITE_* vars), and the API process — launched from the
# repo root via `pnpm --filter @app/api dev` — reads that root `.env`. This
# per-package template exists as documentation of the exact subset the API
# requires; keep its variable names and values in sync with the root
# `.env.example`.
#
# Every value below is validated by the Zod env loader at
# packages/api/src/config/env.ts, which fails fast on anything missing or
# malformed (Gate 12).
#
# Format rules: one KEY=VALUE per line; no shell-style ${INTERPOLATION}
# (dotenv parsers differ); never commit a real secret — placeholders only.
# See /docs/decision-log.md for the rationale behind each choice.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
# Selects runtime behavior. One of: development | test | production.
# In development the Pino logger uses pino-pretty for readable output; in
# production it emits structured JSON lines.
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string consumed by Prisma (@app/db) and the API.
# Components mirror the docker-compose.yml postgres service (postgres:16-alpine,
# user / password / database = slack / slack / slack_dev) and its mapped 5432
# port. Keep this in sync with the POSTGRES_* values in the root `.env.example`.
DATABASE_URL=postgresql://slack:slack@localhost:5432/slack_dev?schema=public

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Redis connection string used for two purposes:
#   - @socket.io/redis-adapter — cross-instance pub/sub for Socket.io (Rule 2)
#   - the presence service — TTL heartbeat keys (online <60s, away <5min,
#     offline >=5min)
# Port mirrors the docker-compose.yml redis service (redis:7-alpine, 6379).
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Secret used to sign and verify JWTs (HS256) for both HTTP routes and the
# Socket.io handshake. Use 32+ bytes of cryptographically random data.
# Generate one with:  openssl rand -hex 32
# CHANGE THIS before any environment beyond local development.
JWT_SECRET=dev-only-change-me-in-production-please-32chars-min
# Token lifetime; accepts an ms-style duration string ("7d", "1h", "30m", "60s").
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# File uploads
# -----------------------------------------------------------------------------
# Directory where multer disk storage writes uploaded attachments. Relative to
# the API package's working directory, or an absolute path. Express also serves
# this directory for downloads via GET /api/files/:id. Git-ignored — the folder
# itself is kept via uploads/.gitkeep.
FILE_UPLOAD_PATH=./uploads
# Per-file upload cap in megabytes. Enforced server-side by multer's `limits`
# option (MAX_FILE_SIZE_MB * 1024 * 1024 bytes) and client-side by the upload UI
# to fail fast. Must be a positive integer.
MAX_FILE_SIZE_MB=10

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
# Port the Express + Socket.io server listens on (Socket.io is mounted on the
# same HTTP server, so there is no separate WebSocket port). The root Makefile
# derives the readiness URL (http://localhost:$PORT/api/health) from this value
# and polls it before seeding. The web client's VITE_API_URL / VITE_WS_URL point
# at this same origin. Optional — defaults to 3000 when unset.
PORT=3000

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Origin allowed by the API's CORS middleware; must match the web app origin
# (the Vite dev server). Optional — defaults to http://localhost:5173 when unset.
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# bcrypt cost factor for password hashing. Minimum 10 is enforced by the env
# loader. Optional — defaults to 10 when unset.
BCRYPT_ROUNDS=10

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# Pino log level override. One of: fatal | error | warn | info | debug | trace |
# silent. Optional — when unset the logger derives the level from NODE_ENV
# (debug in development, info in test and production).
LOG_LEVEL=debug
